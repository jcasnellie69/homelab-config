{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "workspace: health",
            "type": "shell",
            "command": "python",
            "args": [
                "scripts/session/workspace_health.py",
                "--strict",
                "--report",
                "artifacts/automation/workspace-health-report.json"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "workspace: metadata",
            "type": "shell",
            "command": "python",
            "args": [
                "scripts/session/build_pipeline_metadata.py",
                "--output",
                "artifacts/automation/pipeline-metadata-summary.json"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "workspace: infra artifacts",
            "type": "shell",
            "command": "python",
            "args": [
                "scripts/session/generate_infra_artifacts.py",
                "--alpha-ip",
                "192.168.4.10"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "workspace: currency audit",
            "type": "shell",
            "command": "python",
            "args": [
                "scripts/session/tooling_currency.py",
                "--report",
                "artifacts/automation/tooling-currency-report.json"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "workspace: netbox mcp validate",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-Command",
                "$uvx = [bool](Get-Command uvx -ErrorAction SilentlyContinue); Write-Host \"uvx_available=$uvx\"; Test-Connection 192.168.4.140 -Count 1 | Select-Object Address,Status,Latency; Test-NetConnection 192.168.4.140 -Port 80 | Select-Object ComputerName,RemotePort,TcpTestSucceeded; Test-NetConnection 192.168.4.140 -Port 443 | Select-Object ComputerName,RemotePort,TcpTestSucceeded; uvx --from git+https://github.com/netboxlabs/netbox-mcp-server netbox-mcp-server --help"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "workspace: alpha opnsense readiness",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-Command",
                "Test-NetConnection 192.168.4.10 -Port 22 | Select-Object ComputerName,RemotePort,TcpTestSucceeded; Test-NetConnection 192.168.4.10 -Port 8006 | Select-Object ComputerName,RemotePort,TcpTestSucceeded"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "workspace: gitops monitor",
            "type": "shell",
            "command": "python",
            "args": [
                "scripts/session/workspace_gitops_monitor.py",
                "--report",
                "artifacts/automation/workspace-gitops-monitor-report.json"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "workspace: gitops dry-run",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File",
                "scripts/session/gitops_sync.ps1"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "workspace: gitops apply + push",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File",
                "scripts/session/gitops_sync.ps1",
                "-Apply",
                "-Push"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "workspace: devcontainer smoke",
            "type": "shell",
            "command": "docker",
            "args": [
                "build",
                "-f",
                ".devcontainer/Dockerfile",
                ".devcontainer",
                "-t",
                "homelab-config-devcontainer-smoke"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "workspace: root bootstrap dry-run",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-Command",
                "if (Get-Command bash -ErrorAction SilentlyContinue) { bash scripts/session/bootstrap-root-automation.sh --dry-run } else { Write-Host 'bash not available on this host; skipping root bootstrap dry-run' }"
            ],
            "problemMatcher": []
        },
        {
            "label": "verify workspace automation",
            "type": "shell",
            "command": "python scripts/session/workspace_health.py --strict --report artifacts/automation/workspace-health-report.json && python scripts/session/build_pipeline_metadata.py --output artifacts/automation/pipeline-metadata-summary.json && python scripts/session/workspace_gitops_monitor.py --report artifacts/automation/workspace-gitops-monitor-report.json",
            "isBackground": false,
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "verify root bootstrap script",
            "type": "shell",
            "command": "if (Get-Command bash -ErrorAction SilentlyContinue) { bash -n scripts/session/bootstrap-root-automation.sh } else { Write-Host 'bash not available on this host; skipping syntax check' }",
            "isBackground": false,
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "verify root bootstrap in container",
            "type": "shell",
            "command": "docker run --rm -v \"${PWD}:/workspace\" -w /workspace homelab-config-devcontainer-smoke bash -n scripts/session/bootstrap-root-automation.sh",
            "isBackground": false,
            "problemMatcher": [],
            "group": "test"
        }
    ]
}
